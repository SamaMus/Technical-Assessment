@page "/"
@inject IPriceApiClient PriceApiClient

<h3>Day-Ahead Auction Prices (OMIE)</h3>

<div class="row g-3 align-items-end mb-3">
    <div class="col-auto">
        <label class="form-label">Price Zone</label>
        <select class="form-select" @bind="_priceZoneId">
            <option value="1">Spain (1)</option>
            <option value="2">Portugal (2)</option>
        </select>
    </div>
    <div class="col-auto">
        <label class="form-label">From</label>
        <input type="date" class="form-control" @bind="_from" />
    </div>
    <div class="col-auto">
        <label class="form-label">To</label>
        <input type="date" class="form-control" @bind="_to" />
    </div>
    <div class="col-auto">
        <button class="btn btn-primary" @onclick="SearchAsync" disabled="@_isLoading">
            @(_isLoading ? "Loading..." : "Search")
        </button>
    </div>
</div>

@if (_isLoading)
{
    <div class="spinner-border spinner-border-sm"></div> <span>Fetching prices…</span>
}
else if (_errorMessage is not null)
{
    <div class="alert alert-warning">@_errorMessage</div>
}
else if (_series is not null)
{
    @if (_series.Prices.Count == 0)
    {
        <div class="alert alert-info">No price data available for the selected range.</div>
    }
    else
    {
        <table class="table table-striped table-sm">
            <thead>
                <tr><th>Timestamp (CET)</th><th>Duration (min)</th><th>Price Zone</th><th>Price (€/MWh)</th><th>Published</th></tr>
            </thead>
            <tbody>
                @foreach (var p in _series.Prices)
                {
                    <tr>
                        <td>@p.TimestampCet.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@p.DurationMinutes</td>
                        <td>@p.PriceZoneId</td>
                        <td>@(p.Price?.ToString("0.00") ?? "—")</td>
                        <td>@(p.IsPublished ? "Published" : "Pending")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    private int _priceZoneId = 1;
    private DateOnly _from = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly _to = DateOnly.FromDateTime(DateTime.Today);
    private bool _isLoading;
    private string? _errorMessage;
    private PriceSeriesResponse? _series;

    private async Task SearchAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        _series = null;
        StateHasChanged();

        var result = await PriceApiClient.GetPricesAsync(new PriceQueryParameters(_priceZoneId, _from, _to));
        _isLoading = false;

        if (result.Status == ApiCallStatus.Success) _series = result.Data;
        else if (result.Status == ApiCallStatus.NotFound) _series = new PriceSeriesResponse(_priceZoneId, _from, _to, Array.Empty<PricePointResponse>());
        else _errorMessage = result.ErrorMessage;
    }
}
